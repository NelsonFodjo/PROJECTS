# Local dev only. Copy this file to .env and fill in your key.
# This is baked into the JS bundle at build time and is NOT safe for a
# publicly deployed site — anyone visiting the live build can extract it
# from devtools. Use it only while running `npm run dev` on your own
# machine. For everyone else, the in-app AI Settings panel lets each
# visitor store their own key in their own browser's localStorage.
VITE_GROQ_API_KEY=
